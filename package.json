{
  "name": "@factulink/node",
  "version": "0.2.0",
  "description": "Official Node.js / TypeScript SDK for FactuLink — facturación electrónica CFDI 4.0 (México)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "factulink",
    "facturacloud",
    "cfdi",
    "facturacion",
    "sat",
    "mexico",
    "sdk",
    "anexo20",
    "timbrado"
  ],
  "author": "Yair Chan <iyaircc@alianzadev.codes>",
  "license": "MIT",
  "homepage": "https://github.com/IYair/fc-sdk-node#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IYair/fc-sdk-node.git"
  },
  "bugs": {
    "url": "https://github.com/IYair/fc-sdk-node/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
